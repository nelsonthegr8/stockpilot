# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/stockpilot

# Auth
NEXTAUTH_SECRET=your-secret-here-min-32-chars
AUTH_TRUST_HOST=true

# NEXTAUTH_URL: Do NOT set this when running via Docker Compose.
# NextAuth v5 infers the URL from the request host (AUTH_TRUST_HOST=true handles this).
# Only set NEXTAUTH_URL if you are running outside of Docker (e.g. bare metal / PM2)
# and need to explicitly specify the base URL.
# NEXTAUTH_URL=http://your-server-ip:3000

# Shipping
SHIPPO_API_KEY=

# Sales Channels (stored in DB after setup, these are app-level OAuth credentials)
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Queue
REDIS_URL=redis://redis:6379

# BambuBuddy (stored in AppSettings after setup)
BAMBUBUDDY_API_URL=
BAMBUBUDDY_API_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# App
NEXT_PUBLIC_APP_VERSION=0.1.0
