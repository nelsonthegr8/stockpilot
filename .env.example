# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/stockpilot

# Auth
# IMPORTANT: Set NEXTAUTH_URL to the URL browsers use to reach this server.
# For LAN/server installs, use the server's IP or hostname, NOT localhost.
# Examples:
#   Local machine only:  http://localhost:3000
#   LAN server by IP:    http://192.168.1.50:3000
#   Domain name:         https://stockpilot.yourdomain.com
NEXTAUTH_SECRET=your-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Shipping
SHIPPO_API_KEY=

# Sales Channels (stored in DB after setup, these are app-level OAuth credentials)
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Queue
REDIS_URL=redis://redis:6379

# BambuBuddy (stored in AppSettings after setup)
BAMBUBUDDY_API_URL=
BAMBUBUDDY_API_KEY=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# App
NEXT_PUBLIC_APP_VERSION=0.1.0
