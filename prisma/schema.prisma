generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  PICKER_PACKER
  VIEWER
}

enum BusinessProfileType {
  THREE_D_PRINT
  RETAIL_ARBITRAGE
  DROP_SHIP
  WHOLESALE
}

enum LocationType {
  PRIMARY
  THREE_PL
  IN_TRANSIT
}

enum OrderStatus {
  PENDING
  AWAITING_FULFILLMENT
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ChannelType {
  ETSY
  SHOPIFY
  AMAZON
  EBAY
  MANUAL
}

enum POStatus {
  DRAFT
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

enum PrintJobStatus {
  QUEUED
  SENT_TO_BAMBUBUDDY
  PRINTING
  DONE
  FAILED
}

enum PickListStatus {
  PENDING
  IN_PROGRESS
  COMPLETE
}

enum ButtonStatus {
  UNPAIRED
  PAIRED
  LIT
  ACKNOWLEDGED
}

enum PrinterPurpose {
  SKU_LABEL
  SHIPPING_LABEL
  BOTH
}

enum PrinterConnection {
  NETWORK
  BLUETOOTH
  USB_DIRECT
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         Role      @default(VIEWER)
  active       Boolean   @default(true)
  inviteToken  String?   @unique
  inviteExpiry DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  InventoryAdjustment InventoryAdjustment[]
  PickList            PickList[]
}

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

model Product {
  id                  String              @id @default(cuid())
  name                String
  description         String?
  categoryId          String?
  category            Category?           @relation(fields: [categoryId], references: [id])
  businessProfileType BusinessProfileType
  active              Boolean             @default(true)
  images              String[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  variants            ProductVariant[]
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  attributes Json     @default("{}")
  active     Boolean  @default(true)
  skus       SKU[]
}

model SKU {
  id           String         @id @default(cuid())
  variantId    String
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  sku          String         @unique
  barcode      String?        @unique
  weight       Float?
  weightUnit   String         @default("oz")
  length       Float?
  width        Float?
  height       Float?
  dimUnit      String         @default("in")
  costPrice    Decimal        @default(0) @db.Decimal(10, 2)
  retailPrice  Decimal        @default(0) @db.Decimal(10, 2)
  reorderPoint Int            @default(0)
  reorderQty   Int            @default(0)
  stlFileUrl   String?
  sourceStore  String?
  sourcedDate  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  inventoryLevels     InventoryLevel[]
  adjustments         InventoryAdjustment[]
  orderItems          OrderItem[]
  pickListItems       PickListItem[]
  printJobs           PrintJob[]
  variantPrintConfigs VariantPrintConfig[]
  skuSuppliers        SKUSupplier[]
  poItems             PurchaseOrderItem[]
  packSetting         PackSetting?
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  leadTimeDays Int      @default(7)
  paymentTerms String?
  notes        String?
  createdAt    DateTime @default(now())

  skuSuppliers   SKUSupplier[]
  purchaseOrders PurchaseOrder[]
}

model SKUSupplier {
  id          String   @id @default(cuid())
  skuId       String
  sku         SKU      @relation(fields: [skuId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierSku String?
  cost        Decimal  @default(0) @db.Decimal(10, 2)
  isPreferred Boolean  @default(false)

  @@unique([skuId, supplierId])
}

model Location {
  id      String       @id @default(cuid())
  name    String
  type    LocationType
  address String?
  active  Boolean      @default(true)

  inventoryLevels InventoryLevel[]
  adjustments     InventoryAdjustment[]
  purchaseOrders  PurchaseOrder[]
  printers        Printer[]
}

model InventoryLevel {
  id          String   @id @default(cuid())
  skuId       String
  sku         SKU      @relation(fields: [skuId], references: [id], onDelete: Cascade)
  locationId  String
  location    Location @relation(fields: [locationId], references: [id])
  qty         Int      @default(0)
  reservedQty Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([skuId, locationId])
}

model InventoryAdjustment {
  id            String   @id @default(cuid())
  skuId         String
  sku           SKU      @relation(fields: [skuId], references: [id])
  locationId    String
  location      Location @relation(fields: [locationId], references: [id])
  qty           Int
  reason        String
  referenceId   String?
  referenceType String?
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  createdAt     DateTime @default(now())
}

model PurchaseOrder {
  id           String    @id @default(cuid())
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  locationId   String
  location     Location  @relation(fields: [locationId], references: [id])
  status       POStatus  @default(DRAFT)
  expectedDate DateTime?
  notes        String?
  createdBy    String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  items        PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  skuId       String
  sku         SKU           @relation(fields: [skuId], references: [id])
  qtyOrdered  Int
  qtyReceived Int           @default(0)
  unitCost    Decimal       @default(0) @db.Decimal(10, 2)
  landedCost  Decimal       @default(0) @db.Decimal(10, 2)
}

model SalesChannel {
  id          String      @id @default(cuid())
  name        String
  type        ChannelType
  credentials Json        @default("{}")
  active      Boolean     @default(true)
  lastSyncAt  DateTime?
  createdAt   DateTime    @default(now())
  orders      Order[]
}

model Order {
  id              String        @id @default(cuid())
  channelId       String?
  channel         SalesChannel? @relation(fields: [channelId], references: [id])
  channelOrderId  String?
  status          OrderStatus   @default(PENDING)
  customerName    String?
  customerEmail   String?
  shippingAddress Json          @default("{}")
  subtotal        Decimal       @default(0) @db.Decimal(10, 2)
  shippingCost    Decimal       @default(0) @db.Decimal(10, 2)
  channelFees     Decimal       @default(0) @db.Decimal(10, 2)
  total           Decimal       @default(0) @db.Decimal(10, 2)
  currency        String        @default("USD")
  notes           String?
  priority        Int           @default(0)
  tags            String[]
  packingMode     PackingMode   @default(GUIDED)
  packingNotes    String?
  placedAt        DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  items       OrderItem[]
  pickLists   PickList[]
  shipments   Shipment[]
  printJobs   PrintJob[]
  financial   OrderFinancial?
  webhookLogs WebhookLog[]

  @@unique([channelId, channelOrderId])
}

model WebhookLog {
  id         String   @id @default(cuid())
  source     String   // e.g. "SHOPIFY", "ETSY", "MANUAL"
  topic      String   // e.g. "orders/create", "orders/updated"
  status     String   // "received" | "processed" | "error" | "skipped"
  rawPayload Json
  errorMsg   String?
  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
}

model OutboundLog {
  id           String   @id @default(cuid())
  service      String   // "BAMBUBUDDY", "SHIPPO", etc.
  action       String   // e.g. "queue_print"
  status       String   // "success" | "error"
  requestBody  Json
  responseBody Json?
  errorMsg     String?
  printJobId   String?
  printJob     PrintJob? @relation(fields: [printJobId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

model OrderItem {
  id               String  @id @default(cuid())
  orderId          String
  order            Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  skuId            String
  sku              SKU     @relation(fields: [skuId], references: [id])
  qty              Int
  unitPrice        Decimal @default(0) @db.Decimal(10, 2)
  channelListingId String?
  stockReserved    Boolean @default(false)

  printJobs PrintJob[]
}

model VariantPrintConfig {
  id               String   @id @default(cuid())
  skuId            String
  sku              SKU      @relation(fields: [skuId], references: [id], onDelete: Cascade)
  channelVariantId String
  archiveId        Int
  plateId          Int
  projectId        Int?
  targetModel      String
  filamentType     String
  filamentOverrides Json?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  printJobs PrintJob[]
}

model PrintJob {
  id                   String              @id @default(cuid())
  orderId              String
  order                Order               @relation(fields: [orderId], references: [id])
  orderItemId          String
  orderItem            OrderItem           @relation(fields: [orderItemId], references: [id])
  skuId                String
  sku                  SKU                 @relation(fields: [skuId], references: [id])
  variantPrintConfigId String?
  variantPrintConfig   VariantPrintConfig? @relation(fields: [variantPrintConfigId], references: [id])
  status               PrintJobStatus      @default(QUEUED)
  bambuJobId           Int?
  printerId            String?
  printer              Printer?            @relation(fields: [printerId], references: [id])
  startedAt            DateTime?
  completedAt          DateTime?
  plateClearedAt       DateTime?
  errorMessage         String?
  notes                String?
  createdAt            DateTime            @default(now())

  outboundLogs OutboundLog[]
}

model Printer {
  id         String    @id @default(cuid())
  name       String
  model      String?
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  active     Boolean   @default(true)

  printJobs PrintJob[]
}

model OperatorButton {
  id                     String       @id @default(cuid())
  name                   String
  ipAddress              String
  notifyPath             String       @default("/notify")
  notifyMessageTemplate  String       @default("{\"event\": \"{{status}}\", \"job\": \"{{job_name}}\"}")
  printerName            String
  downstreamMethod       String       @default("POST")
  downstreamUrlTemplate  String?
  downstreamBodyTemplate String?
  status                 ButtonStatus @default(UNPAIRED)
  lastPressedAt          DateTime?
  active                 Boolean      @default(true)
  createdAt              DateTime     @default(now())
}

model PrinterConfig {
  id                String            @id @default(cuid())
  name              String
  purpose           PrinterPurpose
  connectionType    PrinterConnection
  ipAddress         String?
  bluetoothDeviceId String?
  isDefault         Boolean           @default(false)
  active            Boolean           @default(true)
  createdAt         DateTime          @default(now())
}

model PickList {
  id         String         @id @default(cuid())
  status     PickListStatus @default(PENDING)
  assignedTo String?
  assignee   User?          @relation(fields: [assignedTo], references: [id])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  orders    Order[]
  items     PickListItem[]
  packSlips PackSlip[]
}

model PickListItem {
  id             String    @id @default(cuid())
  pickListId     String
  pickList       PickList  @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  skuId          String
  sku            SKU       @relation(fields: [skuId], references: [id])
  locationId     String?
  qtyRequired    Int
  qtyPicked      Int       @default(0)
  scannedBarcode String?
  confirmedAt    DateTime?
}

model PackSlip {
  id          String   @id @default(cuid())
  pickListId  String
  pickList    PickList @relation(fields: [pickListId], references: [id])
  pdf         String?
  generatedAt DateTime @default(now())
}

model Shipment {
  id                  String    @id @default(cuid())
  orderId             String
  order               Order     @relation(fields: [orderId], references: [id])
  carrierId           String?
  serviceLevel        String?
  trackingNumber      String?
  labelUrl            String?
  weight              Float?
  shippoShipmentId    String?
  shippoTransactionId String?
  cost                Decimal?  @db.Decimal(10, 2)
  lengthIn            Float?
  widthIn             Float?
  heightIn            Float?
  weightOz            Float?
  status              String    @default("CREATED")
  shippedAt           DateTime?
  deliveredAt         DateTime?
  voidedAt            DateTime?
  createdAt           DateTime  @default(now())

  boxes ShipmentBox[]
}

model OrderFinancial {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id])
  revenue      Decimal  @default(0) @db.Decimal(10, 2)
  cogs         Decimal  @default(0) @db.Decimal(10, 2)
  shippingCost Decimal  @default(0) @db.Decimal(10, 2)
  channelFees  Decimal  @default(0) @db.Decimal(10, 2)
  netProfit    Decimal  @default(0) @db.Decimal(10, 2)
  computedAt   DateTime @default(now())
}

enum PackingMode {
  GUIDED
  FREESTYLE
}

model BoxPreset {
  id           String   @id @default(cuid())
  name         String
  lengthIn     Float
  widthIn      Float
  heightIn     Float
  maxWeightOz  Float
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  packSettings PackSetting[]
  shipmentBoxes ShipmentBox[]
}

model PackSetting {
  id           String    @id @default(cuid())
  skuId        String
  sku          SKU       @relation(fields: [skuId], references: [id], onDelete: Cascade)
  boxPresetId  String
  boxPreset    BoxPreset @relation(fields: [boxPresetId], references: [id])
  qtyPerBox    Int       @default(1)
  packingNotes String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([skuId])
}

model ShipmentBox {
  id          String     @id @default(cuid())
  shipmentId  String
  shipment    Shipment   @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  boxPresetId String?
  boxPreset   BoxPreset? @relation(fields: [boxPresetId], references: [id])
  lengthIn    Float?
  widthIn     Float?
  heightIn    Float?
  weightOz    Float?
  label       Int        @default(1)
  createdAt   DateTime   @default(now())
}


model AppSetting {
  key       String   @id
  value     String
  encrypted Boolean  @default(false)
  updatedAt DateTime @updatedAt
}
